# Copie ce fichier en .env.local et remplis les valeurs
#
# ============================================================
#  Instagram Graph API — Long-lived access tokens
# ============================================================
#
#  SETUP (faire une fois par compte) :
#
#  1. https://developers.facebook.com → créer une App (Consumer)
#
#  2. Ajouter le produit "Instagram Graph API"
#     Le compte Instagram doit être en mode Creator ou Business.
#
#  3. Générer un short-lived token (1h) :
#     https://developers.facebook.com/tools/explorer
#     Permissions : instagram_basic, pages_show_list
#
#  4. Échanger contre un long-lived token (60 jours) :
#     GET https://graph.instagram.com/access_token
#       ?grant_type=ig_exchange_token
#       &client_id=IG_APP_ID
#       &client_secret=IG_APP_SECRET
#       &access_token={short-lived-token}
#
#  5. Rafraîchir avant expiration (~50j) :
#     GET https://graph.instagram.com/refresh_access_token
#       ?grant_type=ig_refresh_token
#       &access_token={long-lived-token}
#
# ============================================================

IG_TOKEN_BLUE=
IG_TOKEN_PURPLE=
IG_APP_ID=
IG_APP_SECRET=
